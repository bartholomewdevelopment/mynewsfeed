# Copy this to server/.env and fill in values

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/mynewsfeed

# JWT secret — use a long random string
JWT_SECRET=change_me_to_something_long_and_random

# Setup key used to create the initial admin account (POST /api/auth/setup)
SETUP_KEY=your_setup_key_here

# YouTube Data API v3 key — get one at console.cloud.google.com
YOUTUBE_API_KEY=

# Client URL for CORS (change in production)
CLIENT_URL=http://localhost:5173

# Server port
PORT=5001
